{
  "name": "@commit-analyzer/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm --filter @commit-analyzer/shared-types build",
    "build": "tsc",
    "start": "node --enable-source-maps dist/bootstrap.js",
    "predev": "pnpm --filter @commit-analyzer/shared-types build",
    "dev": "tsx watch src/bootstrap.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@commit-analyzer/shared-types": "workspace:*",
    "@nestjs/common": "^11",
    "@nestjs/core": "^11",
    "@nestjs/platform-express": "^11",
    "helmet": "^8",
    "pino": "^9.5.0",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commit-analyzer/eslint-config": "workspace:*",
    "@commit-analyzer/typescript-config": "workspace:*",
    "@nestjs/testing": "^11",
    "@types/express": "^5.0.6",
    "@types/node": "^22.9.0",
    "@types/supertest": "^6",
    "eslint": "^9.14.0",
    "supertest": "^7",
    "tsx": "^4",
    "typescript": "^5.6.3",
    "vitest": "^2"
  }
}
