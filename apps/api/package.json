{
  "name": "@commit-analyzer/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "//": "TODO: `dev` only runs tsc --watch today; wire up a server runtime (e.g. tsx watch src/index.ts) when the api runtime lands.",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "test": "echo \"no tests yet\" && exit 0",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@commit-analyzer/shared-types": "workspace:*",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@commit-analyzer/eslint-config": "workspace:*",
    "@commit-analyzer/typescript-config": "workspace:*",
    "@types/node": "^22.9.0",
    "eslint": "^9.14.0",
    "typescript": "^5.6.3"
  }
}
